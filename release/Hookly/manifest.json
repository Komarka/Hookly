{
  "manifest_version": 3,
  "name": "Hookly",
  "version": "0.1.0",
  "description": "Generate personalized LinkedIn cold messages with Human Score.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://api.groq.com/*"],
  "action": {
    "default_title": "Hookly",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/hookly_logo-16.png",
      "32": "assets/hookly_logo-32.png",
      "48": "assets/hookly_logo-48.png",
      "128": "assets/hookly_logo-128.png"
    }
  },
  "icons": {
    "16": "assets/hookly_logo-16.png",
    "32": "assets/hookly_logo-32.png",
    "48": "assets/hookly_logo-48.png",
    "128": "assets/hookly_logo-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.groq.com"
  }
}
